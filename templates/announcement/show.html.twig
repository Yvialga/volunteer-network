{% extends 'base.html.twig' %}

{% block title %}Announcement{% endblock %}

{% block body %}
    <h1>Announcement</h1>

    <table class="table">
        <tbody>
            <tr>
                <th>Id</th>
                <td>{{ announcement.id }}</td>
            </tr>
            <tr>
                <th>Title</th>
                <td>{{ announcement.title }}</td>
            </tr>
            <tr>
                <th>Message</th>
                <td>{{ announcement.message }}</td>
            </tr>
            <tr>
                <th>Closing_date</th>
                <td>{{ announcement.closingDate ? announcement.closingDate|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>Status</th>
                <td>{{ announcement.status }}</td>
            </tr>
            <tr>
                <th>Opening_date</th>
                <td>{{ announcement.openingDate ? announcement.openingDate|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>Created_at</th>
                <td>{{ announcement.createdAt ? announcement.createdAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
            <tr>
                <th>Updated_at</th>
                <td>{{ announcement.updatedAt ? announcement.updatedAt|date('Y-m-d H:i:s') : '' }}</td>
            </tr>
        </tbody>
    </table>

    <a href="{{ path('app_announcement_index') }}">back to list</a>

    <a href="{{ path('app_announcement_edit', {'id': announcement.id}) }}">edit</a>

    {{ include('announcement/_delete_form.html.twig') }}
{% endblock %}
